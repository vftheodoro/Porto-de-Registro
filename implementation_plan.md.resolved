## 4. Modelo de Dados (SQLite)

### 4.1 Diagrama de Entidades

```mermaid
erDiagram
    LINHAS ||--o{ LINHA_PARADAS : "tem"
    LINHAS ||--o{ HORARIOS : "tem"
    PARADAS ||--o{ LINHA_PARADAS : "pertence a"
    LINHAS ||--o{ TARIFAS : "tem"
    PARADAS ||--o{ TARIFAS : "origem"
    PARADAS ||--o{ TARIFAS : "destino"
    USUARIOS ||--o{ AVISOS : "publica"
    USUARIOS ||--o{ AUDITORIA : "executa"

    LINHAS {
        integer id PK
        text codigo "ex: L001"
        text nome "ex: Registro - Cajati"
        text slug "registro-cajati"
        text descricao
        integer ativa "boolean 0/1"
        text created_at
        text updated_at
    }

    PARADAS {
        integer id PK
        text nome "ex: Terminal Registro"
        text cidade "ex: Registro"
        real latitude
        real longitude
        integer ativa "boolean 0/1"
    }

    LINHA_PARADAS {
        integer id PK
        integer linha_id FK
        integer parada_id FK
        integer ordem "1,2,3..."
        integer tempo_minutos "tempo desde a origem"
    }

    HORARIOS {
        integer id PK
        integer linha_id FK
        text hora_saida "HH:MM"
        text tipo "UTIL, SABADO, DOMINGO, FERIADO"
        integer ativo "boolean 0/1"
        text observacao "ex: Apenas período letivo"
        text created_at
        text updated_at
    }

    TARIFAS {
        integer id PK
        integer linha_id FK
        integer parada_origem_id FK
        integer parada_destino_id FK
        real valor
        text created_at
        text updated_at
    }

    AVISOS {
        integer id PK
        text titulo
        text conteudo
        text tipo "URGENTE, INFORMATIVO, FERIADO"
        integer ativo "boolean 0/1"
        text data_inicio "datetime"
        text data_fim "datetime ou null"
        integer criado_por FK
        text created_at
        text updated_at
    }

    USUARIOS {
        integer id PK
        text nome
        text email
        text senha_hash
        text cargo "ADMIN, GESTOR, OPERADOR"
        integer ativo "boolean 0/1"
        text created_at
        text updated_at
    }

    AUDITORIA {
        integer id PK
        integer usuario_id FK
        text acao "CRIAR, EDITAR, EXCLUIR, LOGIN"
        text entidade "LINHA, HORARIO, AVISO, etc."
        integer entidade_id
        text detalhes "JSON com before/after"
        text ip
        text created_at
    }
```

### 4.2 SQL de Criação

```sql
-- Linhas de ônibus
CREATE TABLE linhas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    codigo TEXT NOT NULL UNIQUE,
    nome TEXT NOT NULL,
    slug TEXT NOT NULL UNIQUE,
    descricao TEXT,
    ativa INTEGER NOT NULL DEFAULT 1,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Paradas (pontos de embarque/desembarque)
CREATE TABLE paradas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nome TEXT NOT NULL,
    cidade TEXT NOT NULL,
    latitude REAL,
    longitude REAL,
    ativa INTEGER NOT NULL DEFAULT 1
);

-- Relação linha ↔ parada (com ordem e tempo)
CREATE TABLE linha_paradas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    linha_id INTEGER NOT NULL REFERENCES linhas(id) ON DELETE CASCADE,
    parada_id INTEGER NOT NULL REFERENCES paradas(id) ON DELETE CASCADE,
    ordem INTEGER NOT NULL,
    tempo_minutos INTEGER NOT NULL DEFAULT 0,
    UNIQUE(linha_id, parada_id)
);

-- Horários de saída
CREATE TABLE horarios (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    linha_id INTEGER NOT NULL REFERENCES linhas(id) ON DELETE CASCADE,
    hora_saida TEXT NOT NULL,
    tipo TEXT NOT NULL CHECK(tipo IN ('UTIL', 'SABADO', 'DOMINGO', 'FERIADO')),
    ativo INTEGER NOT NULL DEFAULT 1,
    observacao TEXT,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Tarifas por trecho
CREATE TABLE tarifas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    linha_id INTEGER NOT NULL REFERENCES linhas(id) ON DELETE CASCADE,
    parada_origem_id INTEGER NOT NULL REFERENCES paradas(id),
    parada_destino_id INTEGER NOT NULL REFERENCES paradas(id),
    valor REAL NOT NULL,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now')),
    UNIQUE(linha_id, parada_origem_id, parada_destino_id)
);

-- Avisos operacionais
CREATE TABLE avisos (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    titulo TEXT NOT NULL,
    conteudo TEXT NOT NULL,
    tipo TEXT NOT NULL CHECK(tipo IN ('URGENTE', 'INFORMATIVO', 'FERIADO')),
    ativo INTEGER NOT NULL DEFAULT 1,
    data_inicio TEXT NOT NULL DEFAULT (datetime('now')),
    data_fim TEXT,
    criado_por INTEGER NOT NULL REFERENCES usuarios(id),
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Usuários do painel administrativo
CREATE TABLE usuarios (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nome TEXT NOT NULL,
    email TEXT NOT NULL UNIQUE,
    senha_hash TEXT NOT NULL,
    cargo TEXT NOT NULL CHECK(cargo IN ('ADMIN', 'GESTOR', 'OPERADOR')),
    ativo INTEGER NOT NULL DEFAULT 1,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Log de auditoria
CREATE TABLE auditoria (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    usuario_id INTEGER NOT NULL REFERENCES usuarios(id),
    acao TEXT NOT NULL,
    entidade TEXT NOT NULL,
    entidade_id INTEGER,
    detalhes TEXT, -- JSON
    ip TEXT,
    created_at TEXT NOT NULL DEFAULT (datetime('now'))
);

-- Índices para performance
CREATE INDEX idx_horarios_linha ON horarios(linha_id, tipo);
CREATE INDEX idx_linha_paradas_linha ON linha_paradas(linha_id, ordem);
CREATE INDEX idx_tarifas_linha ON tarifas(linha_id);
CREATE INDEX idx_avisos_ativo ON avisos(ativo, data_inicio, data_fim);
CREATE INDEX idx_auditoria_data ON auditoria(created_at);
```

